        "fill -68 79 -198 -52 79 -182 basalt",
        "fill -66 80 -196 -54 82 -184 blackstone",
        "fill -63 80 -193 -57 80 -187 lava",
        "fill -61 82 -191 -59 82 -189 obsidian",
        "setblock -60 83 -190 dragon_egg"
