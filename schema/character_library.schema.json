      "nbt": {
        "NoAI": true,
        "Silent": true,
        "PersistenceRequired": true,
        "Invulnerable": true
      },
      "default_pose": {
        "yaw": 0,
        "pitch": 0
      },
      "available_actions": [
        "villager_speak",
        "entity_glow_red"
      ],
      "props": [
        "potion",
        "brewing_stand"
      ]
    },
    {
      "id": "phantom",
      "mc_entity": "minecraft:phantom",
      "nbt": {
        "NoAI": true,
        "Silent": true,
        "PersistenceRequired": true,
        "Invulnerable": true
      },
      "default_pose": {
        "yaw": 0,
        "pitch": 0
      },
      "available_actions": [
        "entity_glow_red"
      ],
      "props": [
        "phantom_membrane"
      ]
    },
    {
      "id": "shulker",
      "mc_entity": "minecraft:shulker",
      "nbt": {
        "NoAI": true,
        "Silent": true,
        "PersistenceRequired": true,
        "Invulnerable": true,
